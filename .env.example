# ── Flask core ──────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# SQLite (default) or any SQLAlchemy-compatible URL
# DATABASE_URL=postgresql://user:pass@localhost/pokerdb

# ── PayPal integration ──────────────────────────────────────────────────────
# Get these from https://developer.paypal.com/dashboard/applications

# Client ID is safe to expose in the browser (used in the JS SDK URL)
PAYPAL_CLIENT_ID=

# Client secret is server-side only — NEVER expose this to the browser
PAYPAL_CLIENT_SECRET=

# 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox

# Webhook ID from PayPal Developer Dashboard → Your App → Webhooks
# Required for signature verification in production.
# Leave blank in sandbox to skip verification during local testing.
PAYPAL_WEBHOOK_ID=your_webhook_id_here
